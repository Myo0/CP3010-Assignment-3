<%- include('../partials/header') %>

<h1><%= book ? 'Edit Book/Manga' : 'Add New Book/Manga' %></h1>

<% if (error) { %>
    <div class="alert-error">
        <% if (error === 'wrong_password') { %>Incorrect admin password. Changes were not saved.
        <% } else { %><%= error %><% } %>
    </div>
<% } %>

<form action="<%= book ? '/books/' + book.id + '/edit' : '/books/create' %>" method="POST">

    <label for="title">Title *</label>
    <input type="text" id="title" name="title" required value="<%= book ? book.title : '' %>">

    <label for="author">Author *</label>
    <input type="text" id="author" name="author" required value="<%= book ? book.author : '' %>">

    <label for="type">Type *</label>
    <select id="type" name="type" required>
        <option value="">-- Select --</option>
        <option value="book" <%= (book && book.type === 'book') ? 'selected' : '' %>>Book</option>
        <option value="manga" <%= (book && book.type === 'manga') ? 'selected' : '' %>>Manga</option>
    </select>

    <label for="volume">Volume # (manga only)</label>
    <input type="number" id="volume" name="volume" min="1" value="<%= (book && book.volume) ? book.volume : '' %>">

    <label for="price">Price ($)</label>
    <input type="number" id="price" name="price" step="0.01" min="0" value="<%= (book && book.price) ? book.price : '' %>">

    <label for="stock">Stock</label>
    <input type="number" id="stock" name="stock" min="0" value="<%= (book && book.stock !== undefined) ? book.stock : '0' %>">

    <label for="genre_id">Genre</label>
    <select id="genre_id" name="genre_id">
        <option value="">-- None --</option>
        <% for (var i = 0; i < genres.length; i++) { %>
        <option value="<%= genres[i].id %>" <%= (book && book.genre_id == genres[i].id) ? 'selected' : '' %>><%= genres[i].name %></option>
        <% } %>
    </select>

    <label for="publisher_id">Publisher</label>
    <select id="publisher_id" name="publisher_id">
        <option value="">-- None --</option>
        <% for (var i = 0; i < publishers.length; i++) { %>
        <option value="<%= publishers[i].id %>" <%= (book && book.publisher_id == publishers[i].id) ? 'selected' : '' %>><%= publishers[i].name %></option>
        <% } %>
    </select>

    <label for="description">Description</label>
    <textarea id="description" name="description" rows="4"><%= (book && book.description) ? book.description : '' %></textarea>

    <% if (book) { %>
    <label for="admin_password" style="color:red;">Admin Password (required to save changes)</label>
    <input type="password" id="admin_password" name="admin_password" class="admin-input" placeholder="Admin password">
    <% } %>

    <br>
    <button type="submit" class="btn"><%= book ? 'Save Changes' : 'Add to Inventory' %></button>
    <a href="<%= book ? '/books/' + book.id : '/books' %>" class="btn">Cancel</a>

</form>

<%- include('../partials/footer') %>
