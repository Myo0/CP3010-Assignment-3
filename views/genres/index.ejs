<%- include('../partials/header') %>

<h1>Genres</h1>
<a href="/genres/create" class="btn">+ Add Genre</a>

<% if (genres.length === 0) { %>
    <p>No genres added yet.</p>
<% } else { %>
<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Books</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        <% for (var i = 0; i < genres.length; i++) { %>
        <tr>
            <td><a href="/genres/<%= genres[i].id %>"><%= genres[i].name %></a></td>
            <td><%= genres[i].book_count %></td>
            <td><a href="/genres/<%= genres[i].id %>" class="btn">View</a></td>
        </tr>
        <% } %>
    </tbody>
</table>
<% } %>

<%- include('../partials/footer') %>
